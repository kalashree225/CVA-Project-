DATABASE_URL=postgresql+asyncpg://vision_monitor:vision_monitor_pass@postgres:5432/vision_monitor
REDIS_URL=redis://redis:6379/0
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=my-token
INFLUXDB_ORG=vision-monitor
INFLUXDB_BUCKET=metrics
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vision-monitor-media
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=vision-monitor-embeddings
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
VALID_API_KEYS=key1,key2,key3

# Security — change JWT_SECRET_KEY to a long random string in production
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
